# verana.io-website environment

# Relaticle CRM (contact form -> CRM records). Server-only; never exposed to the
# client. Leave unset in dev: the contact form then accepts and logs without
# writing to the CRM.
RELATICLE_API_URL=https://crm.2060.io
RELATICLE_API_TOKEN=

# Optional ops alert webhook (Discord/Slack-compatible) for CRM write failures.
ALERT_WEBHOOK_URL=

# Google Analytics 4 measurement id (optional; leave empty to disable).
NEXT_PUBLIC_GA_ID=
